# Copy to .env and fill in. NEVER commit the real .env.
PROJECT_ID="your-gcp-project-id"
LOCATION="us-central1"            # Vertex region for text-embedding-004
GEMINI_LOCATION="global"          # Gemini 3 Flash is served from the global endpoint
NURTURER_MODEL="gemini-3-flash-preview"

MONGODB_URI="mongodb+srv://USER:PASS@cluster0.xxxx.mongodb.net/?appName=Cluster0"

RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"
RESEND_FROM_EMAIL="onboarding@resend.dev"
DEMO_TO_EMAIL="you@example.com"   # all demo emails are redirected here
